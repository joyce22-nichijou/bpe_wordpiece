.DS_Store
__pycache__/
*.pyc

# Parsed gold-standard DB pickle caches (regenerated from data/ on first use)
data/.cache/

# Tokenization caches (regenerated by run_eval.py; can be large)
results/reference_free/
results/reference_based/

# Large training corpora (regenerated by load_data.py on first use)
corpus_gutenberg_600books.txt
corpus_gutenberg_1200books.txt
corpus_wikitext103.txt
wordpiece_myself.py

# Generated artifacts (regenerable by running the scripts) —
# keep the folder structure (.gitkeep), ignore the generated JSON output
vocab/**/*.json
results/**/*.json
